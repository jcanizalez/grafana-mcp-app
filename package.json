{
  "name": "grafana-mcp-app",
  "version": "0.1.0",
  "description": "MCP App server that renders interactive Grafana dashboards inside AI conversations",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "grafana-mcp-app": "dist/index.js"
  },
  "scripts": {
    "build": "tsc && npm run copy:ui",
    "copy:ui": "node -e \"const{mkdirSync,copyFileSync,readdirSync}=require('fs');mkdirSync('dist/ui',{recursive:true});readdirSync('src/ui').filter(f=>f.endsWith('.html')).forEach(f=>copyFileSync('src/ui/'+f,'dist/ui/'+f))\"",
    "build:all": "npm run build",
    "start": "node dist/index.js",
    "dev": "node --watch dist/index.js",
    "test": "node --test dist/__tests__/tools.test.js",
    "prepublishOnly": "npm run build:all"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.1",
    "@modelcontextprotocol/ext-apps": "^1.1.2",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.7.0"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/jcanizalez/grafana-mcp-app"
  },
  "keywords": [
    "mcp",
    "mcp-app",
    "grafana",
    "model-context-protocol",
    "ai",
    "claude",
    "dashboard",
    "observability"
  ]
}
