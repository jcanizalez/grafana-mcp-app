{
  "uid": "prometheus-stats-1",
  "title": "Prometheus Stats",
  "tags": ["prometheus", "monitoring"],
  "timezone": "browser",
  "schemaVersion": 41,
  "refresh": "30s",
  "time": { "from": "now-1h", "to": "now" },
  "panels": [
    {
      "id": 1,
      "title": "Scrape Targets Up",
      "type": "stat",
      "gridPos": { "x": 0, "y": 0, "w": 6, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus-default" },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background"
      },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "green", "value": 1 }
            ]
          },
          "mappings": [
            { "type": "value", "options": { "0": { "text": "DOWN" }, "1": { "text": "UP" } } }
          ]
        }
      },
      "targets": [
        {
          "refId": "A",
          "expr": "up",
          "legendFormat": "{{job}} - {{instance}}"
        }
      ]
    },
    {
      "id": 2,
      "title": "Total Scrapes (rate/min)",
      "type": "timeseries",
      "gridPos": { "x": 6, "y": 0, "w": 18, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus-default" },
      "fieldConfig": {
        "defaults": {
          "custom": { "lineWidth": 2, "fillOpacity": 10 }
        }
      },
      "targets": [
        {
          "refId": "A",
          "expr": "rate(prometheus_http_requests_total[5m])",
          "legendFormat": "{{handler}} - {{code}}"
        }
      ]
    },
    {
      "id": 3,
      "title": "TSDB Head Series",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 8, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus-default" },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": { "lineWidth": 2 }
        }
      },
      "targets": [
        {
          "refId": "A",
          "expr": "prometheus_tsdb_head_series",
          "legendFormat": "Active Series"
        }
      ]
    },
    {
      "id": 4,
      "title": "Ingestion Rate (samples/s)",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 8, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus-default" },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": { "lineWidth": 2, "fillOpacity": 10 }
        }
      },
      "targets": [
        {
          "refId": "A",
          "expr": "rate(prometheus_tsdb_head_samples_appended_total[5m])",
          "legendFormat": "Samples/s"
        }
      ]
    }
  ]
}
